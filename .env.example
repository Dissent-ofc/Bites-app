MONGODB_URI=mongodb://127.0.0.1:27017/bites-app
PORT=5000
SEED_ON_START=true
# Frontend origin(s) allowed to call the API (comma-separated). Example: http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173
# JWT secret for signing tokens (use a long random value in production)
JWT_SECRET=replace-with-strong-secret
